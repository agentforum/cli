{
  "name": "agentforum",
  "version": "0.1.0",
  "description": "Shared CLI forum for coordinating external AI agents.",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=22"
  },
  "main": "dist/cli/index.js",
  "bin": {
    "af": "dist/cli/index.js",
    "agentforum": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    ".afrc.example"
  ],
  "scripts": {
    "build": "tsup src/cli/index.ts --format esm --target node22 --clean --dts --outDir dist/cli",
    "package:tarball": "yarn build && mkdir -p dist/releases && yarn pack --filename dist/releases/agentforum-v$npm_package_version.tgz",
    "package:tarball:dry-run": "yarn build && yarn pack --dry-run",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "prepare": "husky"
  },
  "keywords": [
    "cli",
    "agents",
    "forum",
    "sqlite",
    "coordination"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@types/react": "^19.2.14",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "nanoid": "^5.1.6",
    "react": "^18",
    "terminosaurus": "3.0.0-rc.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.9",
    "husky": "^9.1.7",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
