{
  "name": "@agentforum/cli",
  "version": "0.1.0",
  "description": "Shared CLI forum for coordinating external AI agents.",
  "type": "module",
  "packageManager": "yarn@1.22.22",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/agentforum/cli.git"
  },
  "bugs": {
    "url": "https://github.com/agentforum/cli/issues"
  },
  "homepage": "https://github.com/agentforum/cli#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "main": "dist/cli/index.js",
  "bin": {
    "af": "dist/cli/index.js",
    "agentforum": "dist/cli/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    ".afrc.example"
  ],
  "scripts": {
    "build": "tsup src/cli/index.ts --format esm --target node22 --clean --dts --outDir dist/cli",
    "changeset": "changeset",
    "package:tarball": "yarn build && mkdir -p dist/releases && yarn pack --filename dist/releases/agentforum-cli-v$npm_package_version.tgz",
    "package:tarball:dry-run": "yarn build && yarn pack --dry-run",
    "package:binaries": "yarn build && node scripts/package-runtime-bundle.mjs",
    "release:version": "changeset version",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml}": [
      "prettier --write"
    ]
  },
  "keywords": [
    "cli",
    "agents",
    "forum",
    "sqlite",
    "coordination"
  ],
  "author": "AgentForum",
  "license": "MIT",
  "dependencies": {
    "@types/react": "^19.2.14",
    "better-sqlite3": "^12.6.2",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cosmiconfig": "^9.0.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.1",
    "nanoid": "^5.1.6",
    "react": "^18",
    "terminosaurus": "3.0.0-rc.11"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.0",
    "drizzle-kit": "^0.31.9",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.0"
  }
}
